{
  "name": "market-day",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "e2e": "playwright test",
    "e2e:smoke": "npm run e2e:smoke:parallel && npm run e2e:smoke:mutating",
    "e2e:smoke:parallel": "playwright test --grep @smoke --grep-invert @mutating --workers=3",
    "e2e:smoke:mutating": "playwright test --grep @mutating --workers=1",
    "e2e:full": "playwright test --grep-invert \"@destructive|@main-flow\"",
    "e2e:destructive": "playwright test --grep @destructive",
    "e2e:main-flow": "playwright test e2e/event-main-flow.spec.ts --headed --workers=1",
    "e2e:main-flow:demo": "playwright test e2e/event-main-flow.spec.ts --headed --workers=1",
    "e2e:headed": "playwright test --headed",
    "e2e:ui": "playwright test --ui --ui-port=0",
    "e2e:report": "playwright show-report",
    "prepare": "husky"
  },
  "prettier": {
    "printWidth": 100,
    "singleQuote": true,
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/common": "^20.3.0",
    "@angular/compiler": "^20.3.0",
    "@angular/core": "^20.3.0",
    "@angular/forms": "^20.3.0",
    "@angular/localize": "^20.3.21",
    "@angular/platform-browser": "^20.3.0",
    "@angular/router": "^20.3.0",
    "bootstrap": "^5.3.8",
    "bootstrap-icons": "^1.13.1",
    "chart.js": "^4.5.1",
    "rxjs": "~7.8.0",
    "sweetalert2": "^11.26.25",
    "tslib": "^2.3.0",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular/build": "^20.3.26",
    "@angular/cli": "^20.3.26",
    "@angular/compiler-cli": "^20.3.0",
    "@playwright/test": "^1.61.1",
    "@types/jasmine": "~5.1.0",
    "@types/node": "^26.1.1",
    "dotenv": "^17.4.2",
    "husky": "^9.1.7",
    "jasmine-core": "~5.9.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.9.2"
  }
}
